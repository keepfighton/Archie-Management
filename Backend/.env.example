# ─── APP ENV ─────────────────────────────
ENV=production

# ─── JWT (WAJIB GANTI!) ─────────────────
JWT_SECRET=change-this-to-a-very-long-random-secret
JWT_EXP_HOURS=24
APP_URL=http://localhost:3000
UPLOAD_DIR=./uploads

# ─── DATABASE ───────────────────────────
POSTGRES_USER=cbqa
POSTGRES_PASSWORD=cbqa123
POSTGRES_DB=cbqa_db

DB_HOST=postgres
DB_PORT=5432
DB_USER=cbqa
DB_PASSWORD=cbqa123
DB_NAME=cbqa_db

# ─── SMTP (OPSIONAL UNTUK FORGOT PASSWORD) ─────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
