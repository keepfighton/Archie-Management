# ─── APP ENV ─────────────────────────────
ENV=production

# ─── JWT (WAJIB GANTI!) ─────────────────
JWT_SECRET=change-this-to-a-very-long-random-secret
JWT_EXP_HOURS=24
APP_URL=https://management.archieconsultant.com
UPLOAD_DIR=./uploads

# ─── DATABASE ───────────────────────────
POSTGRES_USER=archie_user
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=archie_management_db

DB_HOST=postgres
DB_PORT=5432
DB_USER=archie_user
DB_PASSWORD=CHANGE_THIS_PASSWORD
DB_NAME=archie_management_db

# ─── SMTP (OPSIONAL UNTUK FORGOT PASSWORD) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@archieconsultant.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=info@archieconsultant.com

# ─── WHATSAPP CLOUD API (OPSIONAL UNTUK OWNER REPORT) ─────────────
WHATSAPP_VERIFY_TOKEN=change-this-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v20.0
# Pisahkan dengan koma jika owner lebih dari satu. Gunakan format kode negara, contoh: 6281234567890
WHATSAPP_OWNER_NUMBERS=6281234567890

# ─── PGADMIN (OPTIONAL) ─────────────────
PGADMIN_DEFAULT_EMAIL=admin@archieconsultant.com
PGADMIN_DEFAULT_PASSWORD=admin123
